[Unit]
Description=Reconcile Hermes events every minute

[Timer]
# Realtime anchor, once a minute (at :00). Runs independent of capture so a
# stalled capture loop (capture:last_success_at frozen) surfaces as a
# reconcile.capture_stale finding within the minute.
OnCalendar=*:*:00
Persistent=true
AccuracySec=5s
Unit=hermes-flight-recorder-reconcile.service

[Install]
WantedBy=timers.target
